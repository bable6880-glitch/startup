{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/notification-cleanup",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/reset-order-counts",
      "schedule": "0 19 1 * *"
    },
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "30 0 * * *"
    }
  ]
}
